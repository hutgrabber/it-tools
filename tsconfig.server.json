{
  "compilerOptions": {
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["server/**/*", "src/**/*.ts"],
  "exclude": ["src/**/*.vue", "src/**/*.test.ts", "src/**/*.spec.ts"]
}
